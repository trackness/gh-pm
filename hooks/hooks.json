{
  "description": "Enforcement hooks for gh-pm plugin",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/no-commit-main.sh",
            "timeout": 10,
            "statusMessage": "Checking branch protection..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/no-hook-bypass.sh",
            "timeout": 5,
            "statusMessage": "Checking for hook bypass..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/doc-staleness-check.sh",
            "timeout": 15,
            "statusMessage": "Checking documentation staleness..."
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enforce-agent-model.sh",
            "timeout": 5,
            "statusMessage": "Checking agent model..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enforce-pr-reviewer.sh",
            "timeout": 5,
            "statusMessage": "Checking PR reviewer agent..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/enforce-memory-approval.sh",
            "timeout": 5,
            "statusMessage": "Checking memory write permissions..."
          }
        ]
      }
    ]
  }
}
